# GuinéeMarket Environment Variables
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-this-to-a-random-secret-key

# Database
POSTGRES_USER=guinee_user
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=guinee_marketplace
DATABASE_URL=postgresql://guinee_user:change-this-password@localhost:5432/guinee_marketplace

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-this-jwt-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# MobilePay Guinea API
MOBILEPAY_API_KEY=your-mobilepay-api-key
MOBILEPAY_API_SECRET=your-mobilepay-api-secret
MOBILEPAY_MERCHANT_ID=your-merchant-id
MOBILEPAY_WEBHOOK_SECRET=your-webhook-secret

# SMS Gateway
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=GuineeMarket

# Platform
PLATFORM_COMMISSION_RATE=0.10
MIN_COMMISSION_GNF=5000
