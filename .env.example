# ============================================
# GuinéeMarket - Configuration Template
# Copiez ce fichier en .env et remplissez les valeurs
# ============================================

# Environnement
ENVIRONMENT=development
DEBUG=true
APP_NAME=GuineeMarket
APP_VERSION=1.0.0

# Base de données PostgreSQL
POSTGRES_USER=guinee_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=guinee_marketplace
DATABASE_URL=postgresql://guinee_user:change_me@localhost:5432/guinee_marketplace

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=redis_pass

# Sécurité
SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars
JWT_SECRET_KEY=change-this-jwt-secret-key
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# MobilePay Guinée API
MOBILEPAY_API_KEY=your-mobilepay-api-key
MOBILEPAY_API_SECRET=your-mobilepay-api-secret
MOBILEPAY_BASE_URL=https://api.mobilepayguinee.com/v1
MOBILEPAY_MERCHANT_ID=your-merchant-id
MOBILEPAY_WEBHOOK_SECRET=your-webhook-secret

# SMS Gateway (Orange Guinée)
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=GuineeMarket

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Plateforme
PLATFORM_COMMISSION_RATE=0.10
MIN_COMMISSION_GNF=5000
MERCHANT_PAYOUT_DELAY_HOURS=24

# Upload
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=uploads
